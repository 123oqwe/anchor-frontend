# Required — at least one LLM provider key
ANTHROPIC_API_KEY=sk-ant-...

# Optional — additional providers (system auto-routes to cheapest available)
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_API_KEY=AI...
# QWEN_API_KEY=sk-...

# Server
PORT=3000
# NODE_ENV=production

# Google OAuth (for Gmail + Calendar scanning)
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# Telegram bot (talk to Anchor via Telegram)
# Create bot via @BotFather, paste token here
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Optional features
# MCP_ENABLED=true
# BROWSER_ENABLED=true
